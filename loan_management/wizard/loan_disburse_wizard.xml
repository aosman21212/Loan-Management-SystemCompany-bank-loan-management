<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_loan_disburse_wizard_form" model="ir.ui.view">
        <field name="name">loan.disburse.wizard.form</field>
        <field name="model">loan.disburse.wizard</field>
        <field name="arch" type="xml">
            <form string="Disburse Loan">
                <group string="Loan Information">
                    <field name="loan_id" readonly="1"/>
                    <field name="loan_amount" readonly="1"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <group string="Disbursement Details">
                    <group>
                        <field name="journal_id" required="1"/>
                        <field name="disburse_date" required="1"/>
                    </group>
                    <group>
                        <field name="loan_account_id" required="1"/>
                        <field name="interest_account_id" required="1"/>
                        <field name="date_first_payment" required="1"/>
                    </group>
                </group>
                <group>
                    <field name="note" placeholder="Optional notes about this disbursement..."/>
                </group>
                <footer>
                    <button name="action_disburse"
                            string="Disburse"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
