<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!--  Security Groups                                              -->
        <!-- ============================================================ -->

        <record id="group_loan_user" model="res.groups">
            <field name="name">Loan / User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_loan_manager" model="res.groups">
            <field name="name">Loan / Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_loan_user'))]"/>
        </record>

        <!-- Administrators automatically get manager rights -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_loan_manager'))]"/>
        </record>

        <!-- All internal users get loan user rights -->
        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_loan_user'))]"/>
        </record>

        <!-- ============================================================ -->
        <!--  Record Rules                                                 -->
        <!-- ============================================================ -->

        <!-- Users can only see their own loans (multi-company) -->
        <record id="loan_loan_rule_company" model="ir.rule">
            <field name="name">Loan: Company Rule</field>
            <field name="model_id" ref="model_loan_loan"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_loan_user'))]"/>
        </record>

        <!-- Managers can see all loans across companies they belong to -->
        <record id="loan_loan_rule_manager" model="ir.rule">
            <field name="name">Loan: Manager Rule</field>
            <field name="model_id" ref="model_loan_loan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_loan_manager'))]"/>
        </record>

    </data>
</odoo>
