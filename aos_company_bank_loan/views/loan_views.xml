<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!--  Loan — Form View                                                 -->
    <!-- ================================================================ -->
    <record id="view_loan_form" model="ir.ui.view">
        <field name="name">loan.loan.form</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <form string="Loan">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="aos_company_bank_loan.group_loan_user"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirm'"
                            groups="aos_company_bank_loan.group_loan_manager"/>
                    <button name="action_generate_schedule"
                            string="Generate Schedule"
                            type="object"
                            invisible="state not in ('approve',)"
                            groups="aos_company_bank_loan.group_loan_manager"/>
                    <button name="action_disburse"
                            string="Receive Loan"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approve'"
                            groups="aos_company_bank_loan.group_loan_manager"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancel')"
                            groups="aos_company_bank_loan.group_loan_manager"
                            confirm="Are you sure you want to cancel this loan?"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancel'"
                            groups="aos_company_bank_loan.group_loan_manager"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirm,approve,running,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_installments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-calendar-check-o"
                                invisible="installment_count == 0">
                            <field name="installment_count" widget="statinfo" string="Installments"/>
                        </button>
                        <button name="action_view_moves"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-book"
                                invisible="move_count == 0">
                            <field name="move_count" widget="statinfo" string="Journal Entries"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <!-- Summary banner -->
                    <div class="row" invisible="state == 'draft'">
                        <div class="col-md-3 text-center border-end">
                            <div class="text-muted small">Loan Amount</div>
                            <div class="fw-bold fs-5">
                                <field name="loan_amount" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                        <div class="col-md-3 text-center border-end">
                            <div class="text-muted small">Total Payable</div>
                            <div class="fw-bold fs-5">
                                <field name="total_amount" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                        <div class="col-md-3 text-center border-end">
                            <div class="text-muted small">Amount Paid</div>
                            <div class="fw-bold fs-5 text-success">
                                <field name="amount_paid" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="text-muted small">Outstanding</div>
                            <div class="fw-bold fs-5 text-danger">
                                <field name="amount_residual" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                    </div>
                    <group>
                        <group string="Loan Details" name="loan_details">
                            <field name="loan_type_id"/>
                            <field name="lender_type" widget="radio"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Loan Terms" name="loan_terms">
                            <field name="loan_amount"/>
                            <field name="interest_rate"/>
                            <field name="interest_method"/>
                            <field name="duration"/>
                            <field name="date_application"/>
                            <field name="date_first_payment"/>
                            <field name="date_approve" readonly="1" invisible="not date_approve"/>
                            <field name="date_disburse" readonly="1" invisible="not date_disburse"/>
                        </group>
                    </group>
                    <!-- Computed summary -->
                    <group string="Loan Summary" invisible="total_amount == 0">
                        <group>
                            <field name="emi_amount" readonly="1"/>
                            <field name="total_interest" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_amount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Repayment Schedule" name="schedule">
                            <field name="installment_ids"
                                   context="{'default_loan_id': id}"
                                   readonly="state in ('done', 'cancel')">
                                <list string="Repayment Schedule"
                                      decoration-danger="state == 'overdue'"
                                      decoration-success="state == 'paid'"
                                      decoration-warning="state == 'partial'">
                                    <field name="sequence" string="#"/>
                                    <field name="due_date"/>
                                    <field name="principal_amount"/>
                                    <field name="interest_amount"/>
                                    <field name="total_amount" string="EMI"/>
                                    <field name="balance"/>
                                    <field name="state" widget="badge"
                                           decoration-danger="state == 'overdue'"
                                           decoration-success="state == 'paid'"
                                           decoration-warning="state == 'partial'"
                                           decoration-info="state == 'pending'"/>
                                    <field name="payment_date"/>
                                    <button name="action_pay"
                                            string="Pay"
                                            type="object"
                                            class="btn-sm btn-primary"
                                            icon="fa-check"
                                            invisible="state in ('paid',)"
                                            groups="aos_company_bank_loan.group_loan_user"/>
                                </list>
                            </field>
                        </page>
                        <page string="Accounting" name="accounting">
                            <group>
                                <group>
                                    <field name="journal_id"/>
                                    <field name="loan_account_id"/>
                                    <field name="interest_account_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                            <field name="rejection_reason"
                                   placeholder="Rejection reason..."
                                   invisible="state != 'cancel'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--  Loan — List View                                                 -->
    <!-- ================================================================ -->
    <record id="view_loan_list" model="ir.ui.view">
        <field name="name">loan.loan.list</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <list string="Loans"
                  decoration-danger="state == 'cancel'"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'running'">
                <field name="name"/>
                <field name="loan_type_id"/>
                <field name="lender_type" column_invisible="True"/>
                <field name="partner_id" optional="show" string="Lender / Bank"/>
                <field name="loan_amount"/>
                <field name="duration" string="Months"/>
                <field name="interest_rate" string="Rate %"/>
                <field name="emi_amount" string="EMI"/>
                <field name="total_amount" string="Total Payable" optional="show"/>
                <field name="amount_paid" optional="show"/>
                <field name="amount_residual" optional="show"/>
                <field name="date_application" optional="show"/>
                <field name="user_id" optional="hide" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'cancel'"
                       decoration-success="state == 'done'"
                       decoration-primary="state in ('approve', 'disburse')"
                       decoration-info="state == 'running'"
                       decoration-warning="state == 'confirm'"/>
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--  Loan — Kanban View                                               -->
    <!-- ================================================================ -->
    <record id="view_loan_kanban" model="ir.ui.view">
        <field name="name">loan.loan.kanban</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="loan_type_id"/>
                <field name="lender_type"/>
                <field name="partner_id"/>
                <field name="loan_amount"/>
                <field name="emi_amount"/>
                <field name="total_amount"/>
                <field name="amount_paid"/>
                <field name="state"/>
                <field name="currency_id"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <t t-if="record.partner_id.value">
                                            <field name="partner_id"/>
                                        </t>
                                        <t t-else="">
                                            <field name="name"/>
                                        </t>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="name"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <field name="state" widget="label_selection"
                                           options="{'classes': {'draft': 'secondary', 'confirm': 'warning', 'approve': 'primary', 'disburse': 'primary', 'running': 'info', 'done': 'success', 'cancel': 'danger'}}"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="row">
                                    <div class="col-6">
                                        <span class="text-muted small">Type</span><br/>
                                        <field name="loan_type_id"/>
                                    </div>
                                    <div class="col-6 text-end">
                                        <span class="text-muted small">Amount</span><br/>
                                        <strong><field name="loan_amount"/></strong>
                                    </div>
                                </div>
                                <div class="row mt-1">
                                    <div class="col-6">
                                        <span class="text-muted small">Monthly EMI</span><br/>
                                        <field name="emi_amount"/>
                                    </div>
                                    <div class="col-6 text-end">
                                        <span class="text-muted small">Total Payable</span><br/>
                                        <field name="total_amount"/>
                                    </div>
                                </div>
                                <!-- Progress bar -->
                                <div class="mt-2" t-if="record.total_amount.raw_value > 0">
                                    <div class="text-muted small d-flex justify-content-between">
                                        <span>Paid</span>
                                        <span>
                                            <t t-esc="Math.round(record.amount_paid.raw_value / record.total_amount.raw_value * 100)"/>%
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-success"
                                             t-attf-style="width: #{Math.min(Math.round(record.amount_paid.raw_value / record.total_amount.raw_value * 100), 100)}%">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <img t-att-src="kanban_image('res.users', 'image_128', record.user_id.raw_value)"
                                         t-att-title="record.user_id.value"
                                         class="oe_kanban_avatar o_image_24_cover rounded-circle"
                                         alt="Responsible"/>
                                    <field name="user_id" widget="many2one_avatar_user" readonly="True"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="loan_type_id" widget="badge" class="bg-info"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--  Loan — Search View                                               -->
    <!-- ================================================================ -->
    <record id="view_loan_search" model="ir.ui.view">
        <field name="name">loan.loan.search</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <search string="Loans">
                <field name="name"/>
                <field name="partner_id" string="Lender / Bank"/>
                <field name="loan_type_id"/>
                <field name="user_id"/>
                <!-- Quick filters -->
                <filter string="My Loans" name="my_loans" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirm" domain="[('state', '=', 'confirm')]"/>
                <filter string="Approved" name="approve" domain="[('state', '=', 'approve')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Closed" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancel" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter string="Bank" name="lender_bank" domain="[('lender_type', '=', 'bank')]"/>
                <filter string="Financial Institution" name="lender_fi" domain="[('lender_type', '=', 'financial_institution')]"/>
                <!-- Group by -->
                <group>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Loan Type" name="group_type" context="{'group_by': 'loan_type_id'}"/>
                    <filter string="Lender Type" name="group_lender" context="{'group_by': 'lender_type'}"/>
                    <filter string="Responsible" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Application Date" name="group_date" context="{'group_by': 'date_application:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--  Loan — Actions                                                   -->
    <!-- ================================================================ -->

    <record id="action_loan_all" model="ir.actions.act_window">
        <field name="name">All Loans</field>
        <field name="res_model">loan.loan</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_loan_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No loans yet!
            </p>
            <p>
                Create a new loan to get started with bank loan management.
            </p>
        </field>
    </record>

    <record id="action_loan_my" model="ir.actions.act_window">
        <field name="name">My Loans</field>
        <field name="res_model">loan.loan</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_loan_search"/>
        <field name="context">{'search_default_my_loans': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You have no loans assigned to you.
            </p>
        </field>
    </record>


</odoo>
